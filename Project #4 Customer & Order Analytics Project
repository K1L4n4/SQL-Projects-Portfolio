The BIT_DB is a small database with monthly sales information.

Tables: 
customers : order_id, acctnum
JanSales: orderID, Product, Quantity, price, orderdate, location
FebSales: orderID, Product, Quantity, price, orderdate, location
MarSales: orderID, Product, Quantity, price, orderdate, location
AprSales: orderID, Product, Quantity, price, orderdate, location
MaySales: orderID, Product, Quantity, price, orderdate, location

        
------------

--Question #1. How many unique orders were placed in January? In other words, how many distinct order ids do we have?

SELECT * FROM BIT_DB.JanSales; -- Check the data under Order_IDs to check for any missing or incorrect values


SELECT COUNT(DISTINCT JanSales.orderID) AS Number_Orders  --Counts the number of distinct Order IDs
FROM BIT_DB.JanSales
WHERE length(JanSales.orderID) = 6      --Remove missing values and text; Order IDs consist of 6 digit numbers
    AND JanSales.orderID <> 'Order ID'
;

--Question #2. How many of those orders were for an iPhone?

SELECT COUNT(DISTINCT JanSales.orderID) AS Number_Orders  --Counts the number of distinct Order IDs
FROM BIT_DB.JanSales
WHERE length(JanSales.orderID) = 6      --Remove missing values and text; Order IDs consist of 6 digit numbers
    AND JanSales.orderID <> 'Order ID'
    AND JanSales.Product = 'iPhone'
;

--Question #3. Select the customer account numbers for all the orders that were placed in February.

SELECT
    DISTINCT customers.acctnum,
    FebSales.orderID
FROM customers
INNER JOIN FebSales
ON customers.order_id = FebSales.orderID
WHERE customers.order_id <> 'Order ID' AND length (customers.order_id)= 6
;

--Question #4. Which product was the cheapest one sold in January, and what was the price?

SELECT
    JanSales.Product,
    MIN(JanSales.price)
FROM JanSales
WHERE length(JanSales.orderID) = 6      --Remove missing values and text; Order IDs consist of 6 digit numbers
    AND JanSales.orderID <> 'Order ID'

;

--Question #5. What is the total revenue for each product sold in January?
--(Revenue can be calculated using the number of products sold and the price of the products).

SELECT
    JanSales.Product,
    SUM(JanSales.Quantity)*JanSales.price AS 'Revenue'
FROM BIT_DB.JanSales
WHERE length(JanSales.orderID) = 6 AND JanSales.orderID <> 'Order ID'
GROUP BY JanSales.Product
;

--Question #6. Which products were sold in February at 548 Lincoln St, Seattle, WA 98101, how many of each were sold, and what was the total revenue?

SELECT
    FebSales.Product,
    SUM(FebSales.Quantity),
    SUM(FebSales.Quantity)*FebSales.price AS 'Revenue'
FROM BIT_DB.FebSales
WHERE FebSales.location = '548 Lincoln St, Seattle, WA 98101'
GROUP BY FebSales.Product
;

--Question #7. How many customers ordered more than 2 products at a time in February, and what was the average amount spent for those customers?

SELECT
    COUNT(DISTINCT customers.acctnum),
    AVG(FebSales.Quantity*FebSales.price) AS 'Avg Sales'
FROM BIT_DB.customers
RIGHT JOIN BIT_DB.FebSales
ON customers.order_id = FebSales.orderID
WHERE FebSales.Quantity > 2 AND length(FebSales.orderID) = 6 AND FebSales.orderID <> 'Order ID'
;

------------------ PART 2
--Query 1. How many of each type of headphone were sold in February?

--In other words, what is the sum of the quantity of products sold that have “headphones” in the name from the February dataset? Group the results by product.

SELECT
    FebSales.Product,    
    SUM(FebSales.Quantity)
FROM BIT_DB.FebSales
WHERE FebSales.Product LIKE '%Headphones%' AND FebSales.orderID <> 'Order ID' AND length(FebSales.orderID) = 6
GROUP BY FebSales.Product
;

--Query 2.What was the average amount spent per account in February?

--In other words, what is the average amount spent / number of accounts, not the amount spent by each account.


SELECT
    AVG(FebSales.Quantity*FebSales.price) AS 'Avg spent per account'
FROM BIT_DB.customers
    RIGHT JOIN BIT_DB.FebSales
    ON customers.order_id = FebSales.orderID
    WHERE FebSales.orderID <> 'Order ID' AND length(FebSales.orderID) = 6
;

--Query 3. Find order ids from Georgia (GA) where the order has an average price greater than $1,000. 
--Only find orders from dates beginning with ‘04/1’. 
--Assume that the dates are stored in the MM/DD/YY HH:MM format.

SELECT
    AprSales.orderID
FROM BIT_DB.AprSales
WHERE length(AprSales.orderID) = 6
AND AprSales.orderID <> 'Order ID'
AND AprSales.orderdate LIKE '04/1%'
AND AprSales.location LIKE '%GA%'
GROUP BY AprSales.orderID
HAVING AVG(AprSales.price) > 1000
;

--Query 4. You’ve been given the following results from the MaySales table. Can you reverse engineer a SQL query that returns these results?

--The result set will naturally only return 10 rows (i.e., you will not have to use LIMIT to get to 10 results).

SELECT
   MaySales.location,
   MaySales.orderID
FROM BIT_DB.MaySales
WHERE MaySales.orderID <> 'Order ID' AND length (MaySales.orderID) = 6 AND MaySales.orderID LIKE '1943_5'
ORDER BY MaySales.orderID
;

--Query 5. Which product brought in the most revenue in January and how much revenue did it bring in total?

--In other words, show the one product that generated the most revenue (revenue being equivalent to quantity of an item multiplied by the item’s price). 

SELECT
    JanSales.Product,
    SUM(JanSales.Quantity * JanSales.price) AS 'Revenue'
FROM BIT_DB.JanSales
WHERE JanSales.orderID <> 'Order ID' AND length(JanSales.orderID) = 6
GROUP BY JanSales.Product
ORDER BY SUM(JanSales.Quantity * JanSales.price) desc
LIMIT 1
;






